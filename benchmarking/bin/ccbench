#!/usr/bin/env bash

engine1="$1"
engine2="$2"
openings="$3"
out="$4"

shift 4

# todo: use these aswell when score output of engines is implemented
# -draw movenumber=40 movecount=8 score=10 \
# -resign movecount=3 score=400 \
cutechess-cli \
    -engine cmd="$engine1" name="$engine1" option.gui-lag=100 \
    -engine cmd="$engine2" name="$engine2" option.gui-lag=100 \
    -each proto=uci tc=15+0.1 \
    -rounds 1000 -games 2 \
    -openings file="$openings" format=epd order=random -repeat \
    -recover \
    -concurrency 6 \
    -sprt elo0=0 elo1=2.0 alpha=0.05 beta=0.05 \
    -ratinginterval 20 \
    -outcomeinterval 20 \
    -pgnout "$out" \
    "$@"
